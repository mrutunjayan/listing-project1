<% layout("/layouts/boilerplate") %>


<div class="container auth-container">
    <div class="auth-card">
        <div class="text-center mb-5">
             <h2 class="auth-title">Welcome Back</h2>
            <p class="text-muted fw-medium">Unlock your next adventure.</p>
        </div>

        <form action="/login" method="POST" class="needs-validation" novalidate>
            <div class="mb-4">
                <label for="username" class="form-label fw-bold small text-dark ms-1">Username</label>
                <input
                    id="username"
                    name="username"
                    type="text"
                    class="form-control auth-input"
                    placeholder="Enter your username"
                    required
                >
                <div class="invalid-feedback ms-2">Username is required.</div>
            </div>

            <div class="mb-5">
                <label for="password" class="form-label fw-bold small text-dark ms-1">Password</label>
                <input
                    id="password"
                    name="password"
                    type="password"
                    class="form-control auth-input"
                    placeholder="••••••••"
                    required
                >
                <div class="invalid-feedback ms-2">Password is required.</div>
            </div>

            <button class="btn auth-btn w-100">Login</button>
            
            <div class="text-center mt-5">
                <p class="small text-muted mb-0">
                    New here? 
                    <a href="/signup" class="auth-footer-link">Create an account</a>
                </p>
            </div>
        </form>
    </div>
</div>